{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2021",
    "outDir": "build",
    "module": "commonjs",
    "moduleResolution": "node",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "typeRoots": [
      "src/*",
      "types/*"
    ],
    "lib": ["ES2021", "dom"],
    "paths": {
      "@supernovaio/sdk-exporters": ["./node_modules/@supernovaio/sdk-exporters"]
    }
  },
  "include": ["src/**/*", "config.ts"],
  "exclude": ["node_modules", "dist", "build", "tests"]
}
